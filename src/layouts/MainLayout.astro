---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description: string;
  headerImage: string;
}
const { title, description, headerImage } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body
    class="bg-yellow-bg flex flex-col justify-between min-h-screen items-center"
  >
    <figure class="image-container">
      <img class="header-image opacity-85" src={headerImage} alt="Angular" />
    </figure>
    <Header />
    <slot />
    <Footer />
  </body>
</html>
<style>
  @reference "../styles/global.css";

  .header-image {
    @apply w-full h-[30vh] object-cover object-center aspect-video rounded-none;
  }

  .image-container {
    width: 100%;
    position: relative;
    overflow: hidden;
    @apply flex justify-center;
  }

  .image-container::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.5) 0%,
      transparent 30%,
      #faf4e7 100%
    );

    pointer-events: none;
  }
</style>
