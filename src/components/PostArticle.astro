---
import Video from "./Video.astro";

const { videoUrl, tag, title, date, blogUrl } = Astro.props;
---

<article class="bg-[#F9F6F1] rounded-xl shadow-md overflow-hidden">
  <Video videoUrl={videoUrl} />
  <div class="p-6 flex flex-col gap-5 h-[180px] justify-between">
    <div class="flex flex-col gap-0">
      <span class="!text-xs font-medium text-[#3D5A40]">{tag}</span>
      <h3 class="card-title">{title}</h3>
    </div>
    <div class="flex flex-col gap-2">
      <a
        class="border py-1 px-4 rounded w-32 flex justify-center items-center hover:bg-light-olive-green/90 transition-colors"
        href={blogUrl}>Leer 📖</a
      >
      <p class="card-date">{date}</p>
    </div>
  </div>
</article>

<style>
  @reference "../styles/global.css";

  .card-title {
    @apply mt-0 text-lg md:!text-xl text-[#2E2E2E] leading-5;
  }

  .card-date {
    @apply !text-xs text-[#4A5568];
  }
</style>
